#!/usr/bin/env bash
set -euo pipefail

BEDROCK_HOME="${BEDROCK_HOME:-$HOME/.bedrock}"

usage() {
    cat <<'USAGE'
Usage: bedrock [options] <dir> [prompt]

Scaffold a new project with bedrock engineering discipline.

  dir     Target directory (created if it doesn't exist)
  prompt  Optional stack description, e.g. "Python 3.13, uv, pyright strict, pytest"

Options:
  --name <name>  Project name (defaults to directory basename)
  --bare         Copy scaffold files only, skip stack configuration
  -h, --help     Show this help

Commands:
  bedrock update    Pull latest bedrock templates

Examples:
  bedrock ~/dev/my-app "Python 3.13, uv, pyright strict, pytest"
  bedrock --name myapp ~/dev/my-app "Python 3.13, uv, pyright strict, pytest"
  bedrock ~/dev/my-app          # interactive setup
  bedrock --bare ~/dev/my-app   # scaffold only, configure later
USAGE
    exit 1
}

do_update() {
    echo "Updating bedrock..."
    cd "$BEDROCK_HOME" && git pull --ff-only
    echo "Done."
    exit 0
}

gather_stack_info() {
    local dir="$1"
    local prompt_template
    prompt_template=$(cat "$BEDROCK_HOME/prompts/gather-stack.md")
    local gathered=""

    echo "bedrock: interactive stack setup (ctrl-c to abort)"
    echo ""

    while true; do
        local prompt="${prompt_template//\{\{gathered\}\}/${gathered:-Nothing yet.}}"
        local response
        response=$(claude -p "$prompt" 2>/dev/null)

        if [[ "$response" == READY:* ]]; then
            local stack_desc="${response#READY: }"
            echo ""
            echo "bedrock: stack determined: $stack_desc"
            echo "$stack_desc" > "$dir/.claude/init-prompt"
            return 0
        fi

        echo "$response"
        printf "> "
        read -r answer
        gathered="${gathered}
Q: ${response}
A: ${answer}"
    done
}

# Parse arguments
BARE=false
NAME=""

[ $# -lt 1 ] && usage

while [[ $# -gt 0 ]]; do
    case "$1" in
        update) do_update ;;
        -h|--help) usage ;;
        --bare) BARE=true; shift ;;
        --name) NAME="$2"; shift 2 ;;
        -*) echo "Unknown option: $1"; usage ;;
        *) break ;;
    esac
done

[ $# -lt 1 ] && usage

DIR="$1"
PROMPT="${2:-}"

# Create target directory
mkdir -p "$DIR"
DIR="$(cd "$DIR" && pwd)"

# Default project name to directory basename
NAME="${NAME:-$(basename "$DIR")}"

# Copy scaffold files
mkdir -p "$DIR/.claude/commands"
cp "$BEDROCK_HOME/CLAUDE.md" "$DIR/CLAUDE.md"
cp "$BEDROCK_HOME/PROGRESS.md" "$DIR/PROGRESS.md"
cp "$BEDROCK_HOME/.claude/commands/"*.md "$DIR/.claude/commands/"

# Git init if not already a repo
if [ ! -d "$DIR/.git" ]; then
    git -C "$DIR" init
fi

echo "bedrock: scaffolded $DIR"

if [ "$BARE" = true ]; then
    echo "bedrock: bare mode — run 'claude' in $DIR and use /stack to configure"
    exit 0
fi

# Determine stack: direct prompt, interactive gathering
if [ -z "$PROMPT" ]; then
    gather_stack_info "$DIR"
else
    echo "$PROMPT" > "$DIR/.claude/init-prompt"
fi

# Prepend project name to init-prompt
local_prompt=$(cat "$DIR/.claude/init-prompt")
echo "Project name: ${NAME}
${local_prompt}" > "$DIR/.claude/init-prompt"

# Launch claude with /stack
echo "bedrock: launching claude with /stack..."
cd "$DIR" && claude --prompt "/stack"
