#!/usr/bin/env bash
set -euo pipefail

BEDROCK_HOME="${BEDROCK_HOME:-$HOME/.bedrock}"

usage() {
    cat <<'USAGE'
Usage: bedrock [options] <dir> [prompt]

Scaffold a new project with bedrock engineering discipline.

Arguments:
  dir     Target directory (created if it doesn't exist)
  prompt  Optional stack description, e.g. "Python 3.13, uv, pyright strict, pytest"

Options:
  --name <name>  Project name (defaults to directory basename)
  --bare         Copy scaffold files only, skip stack configuration
  --headless     Run /stack non-interactively and exit
  -h, --help     Show this help

Commands:
  bedrock sync       Sync bedrock files into the current project
  bedrock update     Pull latest bedrock templates
  bedrock version    Show installed version

Examples:
  bedrock ~/dev/my-app "Python 3.13, uv, pyright strict, pytest"
  bedrock --name myapp ~/dev/my-app "Python 3.13, uv, pyright strict, pytest"
  bedrock ~/dev/my-app          # interactive setup
  bedrock --bare ~/dev/my-app   # scaffold only, configure later
  cd existing-project && bedrock sync   # inject bedrock into existing project
USAGE
}

do_version() {
    local ver
    ver=$(cd "$BEDROCK_HOME" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    echo "bedrock $ver"
    exit 0
}

do_update() {
    echo "Updating bedrock..."
    cd "$BEDROCK_HOME" && git pull --ff-only
    echo "Done."
    exit 0
}

# Sync bedrock files into a project directory.
# Copies rules, commands, stack.yml template, PROGRESS.md.
# Merges hook into .claude/settings.json without clobbering user settings.
# Never touches CLAUDE.md.
do_sync() {
    local dir="${1:-.}"
    dir="$(cd "$dir" && pwd)"

    # Rules (bedrock owns entirely)
    mkdir -p "$dir/.bedrock/rules"
    cp "$BEDROCK_HOME/.bedrock/rules/"*.md "$dir/.bedrock/rules/"

    # Stack config template (only if missing)
    if [ ! -f "$dir/.bedrock/stack.yml" ]; then
        cp "$BEDROCK_HOME/.bedrock/stack.yml" "$dir/.bedrock/stack.yml"
    fi

    # Commands (bedrock owns entirely)
    mkdir -p "$dir/.claude/commands"
    cp "$BEDROCK_HOME/.claude/commands/"*.md "$dir/.claude/commands/"

    # Merge hook into .claude/settings.json
    merge_hook "$dir/.claude/settings.json"

    # PROGRESS.md (only if missing)
    if [ ! -f "$dir/PROGRESS.md" ]; then
        cp "$BEDROCK_HOME/PROGRESS.md" "$dir/PROGRESS.md"
    fi

    # CLAUDE.md (only if missing)
    if [ ! -f "$dir/CLAUDE.md" ]; then
        cp "$BEDROCK_HOME/CLAUDE.md" "$dir/CLAUDE.md"
    fi

    echo "bedrock: synced $dir"
}

# Merge the UserPromptSubmit hook into an existing settings.json.
# Creates the file if it doesn't exist. Preserves existing settings.
merge_hook() {
    local settings_file="$1"
    local hook_cmd='cat "$CLAUDE_PROJECT_DIR/.bedrock/rules/"*.md 2>/dev/null || true'

    mkdir -p "$(dirname "$settings_file")"

    if [ ! -f "$settings_file" ]; then
        # No existing settings — write fresh
        cat > "$settings_file" <<HOOK
{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$hook_cmd"
          }
        ]
      }
    ]
  }
}
HOOK
        return
    fi

    # Check if hook already present
    if grep -q '.bedrock/rules/' "$settings_file" 2>/dev/null; then
        return
    fi

    # Merge hook into existing settings using python (available everywhere)
    python3 -c "
import json, sys

with open('$settings_file') as f:
    settings = json.load(f)

hook_entry = {
    'matcher': '',
    'hooks': [{'type': 'command', 'command': '''$hook_cmd'''}]
}

hooks = settings.setdefault('hooks', {})
ups = hooks.setdefault('UserPromptSubmit', [])
ups.append(hook_entry)

with open('$settings_file', 'w') as f:
    json.dump(settings, f, indent=2)
    f.write('\n')
" 2>/dev/null || {
        echo "bedrock: warning: could not merge hook into $settings_file" >&2
        echo "bedrock: add the UserPromptSubmit hook manually (see .bedrock/settings.json)" >&2
    }
}

gather_stack_info() {
    local dir="$1"
    local prompt_template
    prompt_template=$(cat "$BEDROCK_HOME/prompts/gather-stack.md")
    local gathered=""

    echo "bedrock: interactive stack setup (ctrl-c to abort)"
    echo ""

    while true; do
        local prompt="${prompt_template//\{\{gathered\}\}/${gathered:-Nothing yet.}}"
        local response
        response=$(claude -p "$prompt" 2>/dev/null)

        if [[ "$response" == READY:* ]]; then
            local stack_desc="${response#READY: }"
            echo ""
            echo "bedrock: stack determined: $stack_desc"
            echo "$stack_desc" > "$dir/.claude/init-prompt"
            return 0
        fi

        echo "$response"
        printf "> "
        read -r answer
        gathered="${gathered}
Q: ${response}
A: ${answer}"
    done
}

# Parse arguments
BARE=false
HEADLESS=false
NAME=""

if [ $# -lt 1 ]; then
    usage
    exit 1
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        sync) do_sync; exit 0 ;;
        update) do_update ;;
        version) do_version ;;
        -h|--help) usage; exit 0 ;;
        --bare) BARE=true; shift ;;
        --headless) HEADLESS=true; shift ;;
        --name) NAME="$2"; shift 2 ;;
        -*) echo "Error: unknown option '$1'" >&2; echo "" >&2; usage >&2; exit 1 ;;
        *) break ;;
    esac
done

if [ $# -lt 1 ]; then
    echo "Error: missing required argument <dir>" >&2
    echo "" >&2
    usage >&2
    exit 1
fi

DIR="$1"
PROMPT="${2:-}"

# Create target directory
mkdir -p "$DIR"
DIR="$(cd "$DIR" && pwd)"

# Default project name to directory basename
NAME="${NAME:-$(basename "$DIR")}"

# Git init if not already a repo
if [ ! -d "$DIR/.git" ]; then
    git -C "$DIR" init
fi

# Sync bedrock files into the project
do_sync "$DIR"

echo "bedrock: scaffolded $DIR"

if [ "$BARE" = true ]; then
    echo "bedrock: bare mode — run 'claude' in $DIR and use /stack to configure"
    exit 0
fi

# Determine stack: direct prompt, interactive gathering
if [ -z "$PROMPT" ]; then
    gather_stack_info "$DIR"
else
    echo "$PROMPT" > "$DIR/.claude/init-prompt"
fi

# Prepend project name to init-prompt
local_prompt=$(cat "$DIR/.claude/init-prompt")
echo "Project name: ${NAME}
${local_prompt}" > "$DIR/.claude/init-prompt"

# Launch claude with /stack
if [ "$HEADLESS" = true ]; then
    echo "bedrock: running /stack headless..."
    cd "$DIR" && claude -p --dangerously-skip-permissions "/stack"
else
    echo "bedrock: launching claude with /stack..."
    cd "$DIR" && claude "/stack"
fi
