#!/usr/bin/env bash
set -euo pipefail

BEDROCK_HOME="${BEDROCK_HOME:-$HOME/.bedrock}"

usage() {
    cat <<'USAGE'
Usage: bedrock [options] <dir> [prompt]

Scaffold a new project with bedrock engineering discipline.

  dir     Target directory (created if it doesn't exist)
  prompt  Optional stack description, e.g. "Python 3.13, uv, pyright strict, pytest"

Options:
  --bare  Copy scaffold files only, skip stack configuration
  -h      Show this help

Commands:
  bedrock update    Pull latest bedrock templates

Examples:
  bedrock ~/dev/my-app "Python 3.13, uv, pyright strict, pytest"
  bedrock ~/dev/my-app          # interactive setup
  bedrock --bare ~/dev/my-app   # scaffold only, configure later
USAGE
    exit 1
}

do_update() {
    echo "Updating bedrock..."
    cd "$BEDROCK_HOME" && git pull --ff-only
    echo "Done."
    exit 0
}

gather_stack_info() {
    local dir="$1"
    local gathered=""

    echo "bedrock: interactive stack setup (ctrl-c to abort)"
    echo ""

    while true; do
        response=$(claude -p "You are helping set up a new project. You are gathering stack information interactively.

So far the user has told you:
${gathered:-Nothing yet.}

If you have enough information to fully describe the stack (language, version, type checker, test runner, package manager), respond with EXACTLY this format on the first line:
READY: <one-line stack description>

If you need more information, ask ONE focused question. Keep it short. Do not explain what you already know, just ask the next question." 2>/dev/null)

        # Check if Claude has enough info
        if [[ "$response" == READY:* ]]; then
            prompt="${response#READY: }"
            echo ""
            echo "bedrock: stack determined: $prompt"
            echo "$prompt" > "$dir/.claude/init-prompt"
            return 0
        fi

        # Ask the user
        echo "$response"
        printf "> "
        read -r answer
        gathered="${gathered}
Q: ${response}
A: ${answer}"
    done
}

# Parse arguments
BARE=false
[ $# -lt 1 ] && usage

case "$1" in
    update) do_update ;;
    -h|--help) usage ;;
    --bare) BARE=true; shift ;;
esac

[ $# -lt 1 ] && usage

DIR="$1"
PROMPT="${2:-}"

# Create target directory
mkdir -p "$DIR"
DIR="$(cd "$DIR" && pwd)"

# Copy scaffold files
mkdir -p "$DIR/.claude/commands"
cp "$BEDROCK_HOME/templates/CLAUDE.md" "$DIR/CLAUDE.md"
cp "$BEDROCK_HOME/templates/PROGRESS.md" "$DIR/PROGRESS.md"
cp "$BEDROCK_HOME/templates/commands/"*.md "$DIR/.claude/commands/"

# Git init if not already a repo
if [ ! -d "$DIR/.git" ]; then
    git -C "$DIR" init
fi

echo "bedrock: scaffolded $DIR"

if [ "$BARE" = true ]; then
    echo "bedrock: bare mode — run 'claude' in $DIR and use /stack to configure"
    exit 0
fi

# Determine stack: direct prompt, interactive gathering, or skip
if [ -n "$PROMPT" ]; then
    echo "$PROMPT" > "$DIR/.claude/init-prompt"
else
    gather_stack_info "$DIR"
fi

# Launch claude with /stack
echo "bedrock: launching claude with /stack..."
cd "$DIR" && claude --prompt "/stack"
